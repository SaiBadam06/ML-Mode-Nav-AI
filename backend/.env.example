# ModelNavigator AI - Backend Configuration Sample
# Copy this file to '.env' and fill in your actual API keys.

# 1. Groq API Key (Request analysis and recommendations)
# Get yours at: https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here

# 2. NVIDIA API Key (Architecture visualization)
# Get yours at: https://build.nvidia.com/
NVIDIA_API_KEY=your_nvidia_api_key_here

# 3. Supabase Configuration (Persistence)
# Found in Project Settings > API
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_KEY=your-supabase-anon-key
